{
  "scene": "lv1",
  "label": "Lv1 基礎",
  "description": "中学基礎。be動詞・一般動詞・基本疑問。短く確実に口から出す。",
  "problems": [
    { "id": "lv1-001", "jp": "私は学生です。", "en": "I'm a student.", "alt": ["I am a student."], "function": "basic", "note": "I'm = I am の縮約。会話では必ず縮約。" },
    { "id": "lv1-002", "jp": "これは私のかばんです。", "en": "This is my bag.", "alt": [], "function": "basic", "note": "This is 〜 = これは〜です。" },
    { "id": "lv1-003", "jp": "彼は先生ですか？", "en": "Is he a teacher?", "alt": [], "function": "basic", "note": "be動詞の疑問は前に出すだけ。" },
    { "id": "lv1-004", "jp": "私は犬が好きです。", "en": "I like dogs.", "alt": [], "function": "basic", "note": "一般動詞。一般論の複数は無冠詞 + s。" },
    { "id": "lv1-005", "jp": "コーヒー飲みますか？", "en": "Do you drink coffee?", "alt": [], "function": "basic", "note": "一般動詞の疑問は Do you 〜?。" },
    { "id": "lv1-006", "jp": "私は野菜が好きじゃない。", "en": "I don't like vegetables.", "alt": [], "function": "basic", "note": "否定は don't + 原形。" },
    { "id": "lv1-007", "jp": "彼女は東京に住んでいます。", "en": "She lives in Tokyo.", "alt": [], "function": "basic", "note": "三人称単数は動詞に s。" },
    { "id": "lv1-008", "jp": "今何時ですか？", "en": "What time is it?", "alt": [], "function": "basic", "note": "時刻を聞く定型。it が主語。" },
    { "id": "lv1-009", "jp": "これはいくらですか？", "en": "How much is this?", "alt": [], "function": "basic", "note": "値段を聞く定型。" },
    { "id": "lv1-010", "jp": "トイレはどこですか？", "en": "Where is the bathroom?", "alt": ["Where's the restroom?"], "function": "basic", "note": "海外で最重要。bathroom / restroom。" },
    { "id": "lv1-011", "jp": "あなたの名前は何ですか？", "en": "What's your name?", "alt": ["What is your name?"], "function": "basic", "note": "自己紹介の基本。" },
    { "id": "lv1-012", "jp": "出身はどこですか？", "en": "Where are you from?", "alt": [], "function": "basic", "note": "be from 〜 = 〜出身。" },
    { "id": "lv1-013", "jp": "日本から来ました。", "en": "I'm from Japan.", "alt": [], "function": "basic", "note": "上の答え方。" },
    { "id": "lv1-014", "jp": "英語を話せますか？", "en": "Can you speak English?", "alt": [], "function": "basic", "note": "can = できる。原形が続く。" },
    { "id": "lv1-015", "jp": "少し話せます。", "en": "I can speak a little.", "alt": ["A little."], "function": "basic", "note": "a little = 少し。" },
    { "id": "lv1-016", "jp": "わかりません。", "en": "I don't understand.", "alt": ["I don't get it."], "function": "basic", "note": "聞き取れない時の必須フレーズ。" },
    { "id": "lv1-017", "jp": "もう一度お願いします。", "en": "One more time, please.", "alt": ["Again, please."], "function": "basic", "note": "丁寧に聞き返す最短形。" },
    { "id": "lv1-018", "jp": "ありがとう。", "en": "Thank you.", "alt": ["Thanks."], "function": "basic", "note": "Thanks はカジュアル。" },
    { "id": "lv1-019", "jp": "どういたしまして。", "en": "You're welcome.", "alt": ["No problem."], "function": "basic", "note": "No problem も超頻出。" },
    { "id": "lv1-020", "jp": "すみません（呼びかけ）。", "en": "Excuse me.", "alt": [], "function": "basic", "note": "声をかける/通る時。謝罪の Sorry とは別。" },
    { "id": "lv1-021", "jp": "ごめんなさい。", "en": "I'm sorry.", "alt": ["Sorry."], "function": "basic", "note": "謝罪。" },
    { "id": "lv1-022", "jp": "大丈夫です。", "en": "I'm okay.", "alt": ["It's okay.", "I'm fine."], "function": "basic", "note": "状況で I'm / It's を使い分け。" },
    { "id": "lv1-023", "jp": "これをください。", "en": "I'll take this.", "alt": ["This one, please."], "function": "basic", "note": "買い物の定型。" },
    { "id": "lv1-024", "jp": "助けてください。", "en": "Can you help me?", "alt": ["Help me, please."], "function": "basic", "note": "依頼の基本形。" },
    { "id": "lv1-025", "jp": "今行きます。", "en": "I'm coming.", "alt": [], "function": "basic", "note": "相手の方へ行くは come。現在進行形。" },
    { "id": "lv1-026", "jp": "お腹が空きました。", "en": "I'm hungry.", "alt": [], "function": "basic", "note": "be + 形容詞で状態。" },
    { "id": "lv1-027", "jp": "疲れました。", "en": "I'm tired.", "alt": [], "function": "basic", "note": "同上。" },
    { "id": "lv1-028", "jp": "それが欲しいです。", "en": "I want that.", "alt": ["I'd like that."], "function": "basic", "note": "want は直接的、I'd like は丁寧。" },
    { "id": "lv1-029", "jp": "どこに行くの？", "en": "Where are you going?", "alt": [], "function": "basic", "note": "現在進行形の疑問。" },
    { "id": "lv1-030", "jp": "また明日。", "en": "See you tomorrow.", "alt": ["See you."], "function": "basic", "note": "別れの定番。" },
    { "id": "lv1-031", "jp": "はじめまして。", "en": "Nice to meet you.", "alt": [], "function": "basic", "note": "初対面の挨拶。" },
    { "id": "lv1-032", "jp": "元気です、ありがとう。", "en": "I'm good, thanks.", "alt": ["I'm fine, thank you."], "function": "basic", "note": "How are you? への定番返し。" },
    { "id": "lv1-033", "jp": "あなたはどう？", "en": "How about you?", "alt": ["And you?"], "function": "basic", "note": "質問を返す万能フレーズ。" },
    { "id": "lv1-034", "jp": "これは何ですか？", "en": "What is this?", "alt": ["What's this?"], "function": "basic", "note": "物を尋ねる基本。" },
    { "id": "lv1-035", "jp": "あれは誰ですか？", "en": "Who is that?", "alt": ["Who's that?"], "function": "basic", "note": "人を尋ねる基本。" },
    { "id": "lv1-036", "jp": "今日は暑いね。", "en": "It's hot today.", "alt": [], "function": "basic", "note": "天気は it が主語。" },
    { "id": "lv1-037", "jp": "私もです。", "en": "Me too.", "alt": ["Same here."], "function": "basic", "note": "同意の最短形。" },
    { "id": "lv1-038", "jp": "私は違います。", "en": "Not me.", "alt": [], "function": "basic", "note": "Me too. の否定版。" },
    { "id": "lv1-039", "jp": "本当ですか？", "en": "Really?", "alt": ["Is that true?"], "function": "basic", "note": "驚き・確認の一言。" },
    { "id": "lv1-040", "jp": "わかりました。", "en": "I see.", "alt": ["Got it.", "Okay."], "function": "basic", "note": "理解を示す相槌。" },
    { "id": "lv1-041", "jp": "ちょっと待って。", "en": "Wait a minute.", "alt": ["Hold on."], "function": "basic", "note": "制止・保留。" },
    { "id": "lv1-042", "jp": "急いで！", "en": "Hurry up!", "alt": [], "function": "basic", "note": "急かす命令形。" },
    { "id": "lv1-043", "jp": "気をつけて。", "en": "Be careful.", "alt": ["Watch out!"], "function": "basic", "note": "Watch out! は差し迫った危険。" },
    { "id": "lv1-044", "jp": "がんばって。", "en": "Good luck.", "alt": ["You can do it."], "function": "basic", "note": "応援の定番。" },
    { "id": "lv1-045", "jp": "おめでとう。", "en": "Congratulations.", "alt": ["Congrats."], "function": "basic", "note": "祝いの一言。" },
    { "id": "lv1-046", "jp": "いただきます（食べよう）。", "en": "Let's eat.", "alt": [], "function": "basic", "note": "「いただきます」に直訳なし。Let's eat で代用。" },
    { "id": "lv1-047", "jp": "おいしい！", "en": "It's delicious.", "alt": ["This is good."], "function": "basic", "note": "食べ物の感想。" },
    { "id": "lv1-048", "jp": "もういっぱいです。", "en": "I'm full.", "alt": [], "function": "basic", "note": "満腹。be + 形容詞。" },
    { "id": "lv1-049", "jp": "喉が渇いた。", "en": "I'm thirsty.", "alt": [], "function": "basic", "note": "hungry とセットで覚える。" },
    { "id": "lv1-050", "jp": "眠いです。", "en": "I'm sleepy.", "alt": ["I'm tired."], "function": "basic", "note": "sleepy = 眠い、tired = 疲れた。" },
    { "id": "lv1-051", "jp": "寒いです。", "en": "I'm cold.", "alt": ["It's cold."], "function": "basic", "note": "自分が寒い=I'm、気温=It's。" },
    { "id": "lv1-052", "jp": "ここに座ってもいい？", "en": "Can I sit here?", "alt": [], "function": "basic", "note": "許可を求める Can I 〜?。" },
    { "id": "lv1-053", "jp": "写真を撮ってもいい？", "en": "Can I take a picture?", "alt": [], "function": "basic", "note": "観光の基本。" },
    { "id": "lv1-054", "jp": "電話番号を教えて。", "en": "What's your phone number?", "alt": [], "function": "basic", "note": "連絡先を聞く。" },
    { "id": "lv1-055", "jp": "もう行かなきゃ。", "en": "I have to go.", "alt": ["I need to go."], "function": "basic", "note": "have to = 〜しなければ。" },
    { "id": "lv1-056", "jp": "また後でね。", "en": "See you later.", "alt": ["Talk to you later."], "function": "basic", "note": "別れの定番。" },
    { "id": "lv1-057", "jp": "おやすみなさい。", "en": "Good night.", "alt": [], "function": "basic", "note": "就寝の挨拶。" },
    { "id": "lv1-058", "jp": "良い一日を。", "en": "Have a good day.", "alt": ["Have a nice day."], "function": "basic", "note": "別れ際の決まり文句。" },
    { "id": "lv1-059", "jp": "楽しんでね。", "en": "Have fun.", "alt": ["Enjoy."], "function": "basic", "note": "出かける人へ。" },
    { "id": "lv1-060", "jp": "問題ないよ。", "en": "No problem.", "alt": ["That's fine."], "function": "basic", "note": "感謝・謝罪への返し。" }
  ]
}
