{
  "scene": "lv2",
  "label": "Lv2 日常基本",
  "description": "現在進行・過去形・can/want to・未来。日常を自分の言葉で言える段階。",
  "problems": [
    { "id": "lv2-001", "jp": "今、夕飯を作ってるところ。", "en": "I'm making dinner right now.", "alt": [], "function": "daily", "note": "現在進行形 = 今まさに。" },
    { "id": "lv2-002", "jp": "昨日、友達に会った。", "en": "I met a friend yesterday.", "alt": [], "function": "daily", "note": "meet の過去は met。" },
    { "id": "lv2-003", "jp": "先週、映画を見た。", "en": "I watched a movie last week.", "alt": ["I saw a movie last week."], "function": "daily", "note": "watch / see どちらも可。" },
    { "id": "lv2-004", "jp": "週末は何をしたの？", "en": "What did you do over the weekend?", "alt": ["What did you do this weekend?"], "function": "daily", "note": "did + 原形。" },
    { "id": "lv2-005", "jp": "明日は雨が降ると思う。", "en": "I think it'll rain tomorrow.", "alt": ["I think it's going to rain tomorrow."], "function": "daily", "note": "I think + 文。" },
    { "id": "lv2-006", "jp": "手伝ってくれる？", "en": "Can you give me a hand?", "alt": ["Can you help me out?"], "function": "daily", "note": "give a hand = 手を貸す。" },
    { "id": "lv2-007", "jp": "ちょっと休憩しよう。", "en": "Let's take a break.", "alt": [], "function": "daily", "note": "Let's + 原形 = 〜しよう。" },
    { "id": "lv2-008", "jp": "今日は早く帰りたい。", "en": "I want to go home early today.", "alt": ["I'd like to go home early today."], "function": "daily", "note": "want to + 原形。" },
    { "id": "lv2-009", "jp": "明日は休みです。", "en": "I'm off tomorrow.", "alt": ["I have the day off tomorrow."], "function": "daily", "note": "be off = 休み。" },
    { "id": "lv2-010", "jp": "電車が遅れている。", "en": "The train is delayed.", "alt": ["The train is running late."], "function": "daily", "note": "be delayed = 遅延している。" },
    { "id": "lv2-011", "jp": "道に迷ったかも。", "en": "I think I'm lost.", "alt": [], "function": "daily", "note": "やわらかく言う I think。" },
    { "id": "lv2-012", "jp": "もう少しで着くよ。", "en": "I'll be there soon.", "alt": ["Almost there."], "function": "daily", "note": "未来 will + be there。" },
    { "id": "lv2-013", "jp": "ちょっと遅れます。", "en": "I'll be a little late.", "alt": ["I'm running a bit late."], "function": "daily", "note": "run late = 遅れ気味。" },
    { "id": "lv2-014", "jp": "何か食べに行こうよ。", "en": "Let's go grab something to eat.", "alt": ["Let's get something to eat."], "function": "daily", "note": "grab = さっと取る/食べる。" },
    { "id": "lv2-015", "jp": "今ちょっと忙しい。", "en": "I'm a little busy right now.", "alt": [], "function": "daily", "note": "right now = 今は。" },
    { "id": "lv2-016", "jp": "後でかけ直すね。", "en": "I'll call you back later.", "alt": [], "function": "daily", "note": "call back = かけ直す。" },
    { "id": "lv2-017", "jp": "それ、どこで買ったの？", "en": "Where did you buy that?", "alt": ["Where did you get that?"], "function": "daily", "note": "get = 手に入れる(buy の口語)。" },
    { "id": "lv2-018", "jp": "それ、いいね。", "en": "I like that.", "alt": ["That's nice."], "function": "daily", "note": "褒めの基本。" },
    { "id": "lv2-019", "jp": "ちょっと寒くない？", "en": "Isn't it a little cold?", "alt": [], "function": "daily", "note": "否定疑問 = 〜じゃない？" },
    { "id": "lv2-020", "jp": "窓を閉めてくれる？", "en": "Can you close the window?", "alt": ["Could you close the window?"], "function": "daily", "note": "Could you の方が丁寧。" },
    { "id": "lv2-021", "jp": "もう寝るね。", "en": "I'm going to bed.", "alt": ["I'm off to bed."], "function": "daily", "note": "go to bed = 寝に行く。" },
    { "id": "lv2-022", "jp": "今日は楽しかった。", "en": "I had a great time today.", "alt": ["Today was fun."], "function": "daily", "note": "have a great time = 楽しい時間を過ごす。" },
    { "id": "lv2-023", "jp": "もう食べた？", "en": "Did you eat already?", "alt": ["Have you eaten?"], "function": "daily", "note": "口語では Did 〜 already? も普通。" },
    { "id": "lv2-024", "jp": "まだ決めてない。", "en": "I haven't decided yet.", "alt": ["I'm still not sure."], "function": "daily", "note": "haven't + 過去分詞 + yet。" },
    { "id": "lv2-025", "jp": "それでいいよ。", "en": "That works for me.", "alt": ["That's fine."], "function": "daily", "note": "work for 人 = 都合がいい。" },
    { "id": "lv2-026", "jp": "ちょっと待ってて。", "en": "Hold on a second.", "alt": ["Wait a sec."], "function": "daily", "note": "hold on = 待つ。" },
    { "id": "lv2-027", "jp": "もう行かなきゃ。", "en": "I have to go now.", "alt": ["I gotta go."], "function": "daily", "note": "have to = 〜しなければ。" },
    { "id": "lv2-028", "jp": "気をつけて帰ってね。", "en": "Get home safe.", "alt": ["Get back safe."], "function": "daily", "note": "別れ際の気遣い。" },
    { "id": "lv2-029", "jp": "連絡してね。", "en": "Let me know.", "alt": ["Keep me posted."], "function": "daily", "note": "let me know = 知らせて。" },
    { "id": "lv2-030", "jp": "楽しみにしてるね。", "en": "I'm looking forward to it.", "alt": [], "function": "daily", "note": "look forward to + 名詞/動名詞。" },
    { "id": "lv2-031", "jp": "週末は何してたの？", "en": "What did you do over the weekend?", "alt": [], "function": "daily", "note": "過去の出来事を聞く。" },
    { "id": "lv2-032", "jp": "家でゆっくりしてた。", "en": "I just relaxed at home.", "alt": ["I stayed home and chilled."], "function": "daily", "note": "just = ただ〜してた。" },
    { "id": "lv2-033", "jp": "友達と出かけた。", "en": "I went out with friends.", "alt": [], "function": "daily", "note": "go out = 出かける。" },
    { "id": "lv2-034", "jp": "ちょっと買い物に行った。", "en": "I went shopping for a bit.", "alt": [], "function": "daily", "note": "go shopping。for a bit = ちょっと。" },
    { "id": "lv2-035", "jp": "昨日は遅くまで起きてた。", "en": "I stayed up late last night.", "alt": [], "function": "daily", "note": "stay up late = 夜更かしする。" },
    { "id": "lv2-036", "jp": "朝寝坊しちゃった。", "en": "I overslept this morning.", "alt": [], "function": "daily", "note": "oversleep = 寝過ごす。" },
    { "id": "lv2-037", "jp": "今日は調子いい。", "en": "I'm feeling good today.", "alt": [], "function": "daily", "note": "feel + 形容詞。" },
    { "id": "lv2-038", "jp": "ちょっと体調悪い。", "en": "I'm not feeling well.", "alt": ["I feel sick."], "function": "daily", "note": "not feeling well = 体調が悪い。" },
    { "id": "lv2-039", "jp": "風邪をひいたみたい。", "en": "I think I caught a cold.", "alt": [], "function": "daily", "note": "catch a cold = 風邪をひく。" },
    { "id": "lv2-040", "jp": "病院に行ったほうがいい。", "en": "You should see a doctor.", "alt": [], "function": "daily", "note": "see a doctor = 医者に診てもらう。" },
    { "id": "lv2-041", "jp": "何時に会う？", "en": "What time should we meet?", "alt": [], "function": "daily", "note": "should we = 〜しようか。" },
    { "id": "lv2-042", "jp": "駅で待ち合わせよう。", "en": "Let's meet at the station.", "alt": [], "function": "daily", "note": "meet at + 場所。" },
    { "id": "lv2-043", "jp": "もう着いた？", "en": "Are you here yet?", "alt": ["Did you arrive?"], "function": "daily", "note": "yet = もう(疑問文)。" },
    { "id": "lv2-044", "jp": "あと5分で着くよ。", "en": "I'll be there in five minutes.", "alt": [], "function": "daily", "note": "in + 時間 = 〜後に。" },
    { "id": "lv2-045", "jp": "今どこ？", "en": "Where are you now?", "alt": [], "function": "daily", "note": "現在地を聞く。" },
    { "id": "lv2-046", "jp": "迎えに行こうか？", "en": "Do you want me to pick you up?", "alt": [], "function": "daily", "note": "pick up = 車で迎える。" },
    { "id": "lv2-047", "jp": "それ手伝おうか？", "en": "Do you want me to help?", "alt": ["Need a hand?"], "function": "daily", "note": "申し出の Do you want me to 〜?。" },
    { "id": "lv2-048", "jp": "自分でできるよ。", "en": "I can do it myself.", "alt": [], "function": "daily", "note": "myself = 自分で。" },
    { "id": "lv2-049", "jp": "やってみるよ。", "en": "I'll give it a try.", "alt": ["I'll try."], "function": "daily", "note": "give it a try = 試す。" },
    { "id": "lv2-050", "jp": "うまくいくといいね。", "en": "I hope it goes well.", "alt": [], "function": "daily", "note": "I hope + 文。" },
    { "id": "lv2-051", "jp": "それ面白そう。", "en": "That sounds interesting.", "alt": ["That sounds fun."], "function": "daily", "note": "sound + 形容詞。" },
    { "id": "lv2-052", "jp": "ちょっと疲れちゃった。", "en": "I'm a bit tired.", "alt": [], "function": "daily", "note": "a bit = ちょっと。" },
    { "id": "lv2-053", "jp": "そろそろ帰ろうかな。", "en": "I think I'll head home soon.", "alt": [], "function": "daily", "note": "head home = 帰路につく。" },
    { "id": "lv2-054", "jp": "今日はありがとう、楽しかった。", "en": "Thanks for today, I had fun.", "alt": [], "function": "daily", "note": "had fun = 楽しかった。" },
    { "id": "lv2-055", "jp": "また誘ってね。", "en": "Let's do this again.", "alt": ["Invite me again."], "function": "daily", "note": "do this again = また同じことをしよう。" },
    { "id": "lv2-056", "jp": "後で写真送るね。", "en": "I'll send you the photos later.", "alt": [], "function": "daily", "note": "send 人 物。" },
    { "id": "lv2-057", "jp": "ちょっと聞いてもいい？", "en": "Can I ask you something?", "alt": [], "function": "daily", "note": "本題前のクッション。" },
    { "id": "lv2-058", "jp": "それどういう意味？", "en": "What do you mean by that?", "alt": [], "function": "daily", "note": "by that = それで(の意味)。" },
    { "id": "lv2-059", "jp": "もう一回言ってくれる？", "en": "Can you say that again?", "alt": [], "function": "daily", "note": "聞き返しの基本。" },
    { "id": "lv2-060", "jp": "なるほど、わかった。", "en": "Oh, I get it now.", "alt": ["Now I understand."], "function": "daily", "note": "get it = 理解する。" },
    { "id": "lv2-061", "jp": "最近どう過ごしてる？", "en": "What have you been up to lately?", "alt": [], "function": "daily", "note": "be up to = 〜して過ごす。" },
    { "id": "lv2-062", "jp": "相変わらず忙しいよ。", "en": "Same as always, pretty busy.", "alt": [], "function": "daily", "note": "same as always = 相変わらず。" },
    { "id": "lv2-063", "jp": "新しい趣味を始めたんだ。", "en": "I picked up a new hobby.", "alt": [], "function": "daily", "note": "pick up = (趣味を)始める。" },
    { "id": "lv2-064", "jp": "最近ジムに通ってる。", "en": "I've been going to the gym lately.", "alt": [], "function": "daily", "note": "have been -ing = 最近ずっと。" },
    { "id": "lv2-065", "jp": "ちょっと太っちゃった。", "en": "I've gained a little weight.", "alt": [], "function": "daily", "note": "gain weight = 太る。" },
    { "id": "lv2-066", "jp": "そろそろ何か食べようか。", "en": "Should we get something to eat?", "alt": [], "function": "daily", "note": "Should we 〜? = 〜しようか。" },
    { "id": "lv2-067", "jp": "何が食べたい？", "en": "What do you feel like eating?", "alt": [], "function": "daily", "note": "feel like -ing = 〜したい気分。" },
    { "id": "lv2-068", "jp": "なんでもいいよ。", "en": "Anything is fine with me.", "alt": [], "function": "daily", "note": "fine with me = 私はOK。" },
    { "id": "lv2-069", "jp": "ここから近い？", "en": "Is it close to here?", "alt": [], "function": "daily", "note": "close to = 近い。" },
    { "id": "lv2-070", "jp": "歩いて10分くらい。", "en": "It's about a ten-minute walk.", "alt": [], "function": "daily", "note": "a ten-minute walk = 徒歩10分。" },
    { "id": "lv2-071", "jp": "今日は奢るよ。", "en": "It's on me today.", "alt": [], "function": "daily", "note": "on me = おごり。" },
    { "id": "lv2-072", "jp": "悪いね、ありがとう。", "en": "You sure? Thanks a lot.", "alt": [], "function": "daily", "note": "You sure? = いいの?。" },
    { "id": "lv2-073", "jp": "今度は私が出すね。", "en": "I'll get it next time.", "alt": [], "function": "daily", "note": "get it = 支払う。" },
    { "id": "lv2-074", "jp": "明日って空いてる？", "en": "Are you free tomorrow?", "alt": [], "function": "daily", "note": "be free = 空いている。" },
    { "id": "lv2-075", "jp": "午後なら大丈夫。", "en": "I'm okay in the afternoon.", "alt": [], "function": "daily", "note": "in the afternoon。" },
    { "id": "lv2-076", "jp": "予定確認して連絡するね。", "en": "I'll check my schedule and let you know.", "alt": [], "function": "daily", "note": "let you know = 知らせる。" },
    { "id": "lv2-077", "jp": "ドタキャンしてごめん。", "en": "Sorry for canceling last minute.", "alt": [], "function": "daily", "note": "last minute = 直前。" },
    { "id": "lv2-078", "jp": "気にしないで、また今度。", "en": "No worries, some other time.", "alt": [], "function": "daily", "note": "some other time = また今度。" },
    { "id": "lv2-079", "jp": "久しぶりに会えてよかった。", "en": "It was great to see you again.", "alt": [], "function": "daily", "note": "see you again = 再会。" },
    { "id": "lv2-080", "jp": "気をつけて帰ってね。", "en": "Get home safe, okay?", "alt": [], "function": "daily", "note": "get home safe = 無事に帰る。" }
  ]
}
