{
  "scene": "lv3",
  "label": "Lv3 会話標準",
  "description": "現在完了・助動詞・比較・句動詞入門。普通の会話を回せる標準レベル。",
  "problems": [
    { "id": "lv3-001", "jp": "彼にはもう連絡した。", "en": "I've already contacted him.", "alt": ["I already reached out to him."], "function": "standard", "note": "現在完了 + already。" },
    { "id": "lv3-002", "jp": "そんな話聞いたことない。", "en": "I've never heard of that.", "alt": [], "function": "standard", "note": "hear of = 〜について聞く。" },
    { "id": "lv3-003", "jp": "3年間ここで働いている。", "en": "I've been working here for three years.", "alt": [], "function": "standard", "note": "現在完了進行 = ずっと〜している。" },
    { "id": "lv3-004", "jp": "もっと早く言ってくれればよかったのに。", "en": "You should have told me earlier.", "alt": [], "function": "standard", "note": "should have + 過去分詞。" },
    { "id": "lv3-005", "jp": "それはあり得る。", "en": "That could happen.", "alt": ["That's possible."], "function": "standard", "note": "could = 可能性。" },
    { "id": "lv3-006", "jp": "やっておくべきだよ。", "en": "You should get it done.", "alt": [], "function": "standard", "note": "get it done = 終わらせる。" },
    { "id": "lv3-007", "jp": "彼の方が私より背が高い。", "en": "He's taller than me.", "alt": [], "function": "standard", "note": "比較級 + than。" },
    { "id": "lv3-008", "jp": "これが一番いいと思う。", "en": "I think this is the best one.", "alt": [], "function": "standard", "note": "the + 最上級。" },
    { "id": "lv3-009", "jp": "思ったより簡単だった。", "en": "It was easier than I thought.", "alt": [], "function": "standard", "note": "than I thought = 思ったより。" },
    { "id": "lv3-010", "jp": "その件、調べておくよ。", "en": "I'll look into it.", "alt": [], "function": "standard", "note": "look into = 調査する(句動詞)。" },
    { "id": "lv3-011", "jp": "結局、行かなかった。", "en": "I ended up not going.", "alt": [], "function": "standard", "note": "end up + -ing = 結局〜になる。" },
    { "id": "lv3-012", "jp": "それ、なんとかするよ。", "en": "I'll figure it out.", "alt": [], "function": "standard", "note": "figure out = 解決/理解する。" },
    { "id": "lv3-013", "jp": "予定が合わなくて。", "en": "It didn't work out with my schedule.", "alt": [], "function": "standard", "note": "work out = うまくいく。" },
    { "id": "lv3-014", "jp": "もう一度確認させて。", "en": "Let me double-check.", "alt": [], "function": "standard", "note": "double-check = 念のため確認。" },
    { "id": "lv3-015", "jp": "それは考えたことなかった。", "en": "I hadn't thought of that.", "alt": [], "function": "standard", "note": "過去完了 = それ以前に。" },
    { "id": "lv3-016", "jp": "急がなくていいよ。", "en": "You don't have to rush.", "alt": ["Take your time."], "function": "standard", "note": "don't have to = 〜しなくてよい。" },
    { "id": "lv3-017", "jp": "そうとは限らない。", "en": "That's not necessarily true.", "alt": [], "function": "standard", "note": "not necessarily = 必ずしも〜でない。" },
    { "id": "lv3-018", "jp": "場合によるね。", "en": "It depends.", "alt": ["That depends."], "function": "standard", "note": "会話超頻出の一言。" },
    { "id": "lv3-019", "jp": "正直、どっちでもいい。", "en": "Honestly, either works.", "alt": ["I don't really mind."], "function": "standard", "note": "either = どちらでも。" },
    { "id": "lv3-020", "jp": "そう言われればそうだね。", "en": "Now that you mention it, you're right.", "alt": [], "function": "standard", "note": "now that = 〜した今となっては。" },
    { "id": "lv3-021", "jp": "なるべく早く返信します。", "en": "I'll get back to you as soon as I can.", "alt": ["I'll reply ASAP."], "function": "standard", "note": "as soon as I can = できるだけ早く。" },
    { "id": "lv3-022", "jp": "それは聞いてなかった。", "en": "I wasn't told about that.", "alt": ["Nobody told me that."], "function": "standard", "note": "受動態。" },
    { "id": "lv3-023", "jp": "やってみる価値はある。", "en": "It's worth a try.", "alt": ["It's worth a shot."], "function": "standard", "note": "worth + 名詞 = 〜の価値がある。" },
    { "id": "lv3-024", "jp": "もう慣れたよ。", "en": "I've gotten used to it.", "alt": [], "function": "standard", "note": "get used to = 慣れる(完了形)。" },
    { "id": "lv3-025", "jp": "そろそろ決めないと。", "en": "We need to decide soon.", "alt": [], "function": "standard", "note": "need to = 〜する必要がある。" },
    { "id": "lv3-026", "jp": "それ、誰がやるの？", "en": "Who's going to do that?", "alt": ["Who's taking care of that?"], "function": "standard", "note": "be going to の疑問。" },
    { "id": "lv3-027", "jp": "そのうちわかるよ。", "en": "You'll find out eventually.", "alt": [], "function": "standard", "note": "find out = 判明する。eventually = そのうち。" },
    { "id": "lv3-028", "jp": "言いにくいんだけど…", "en": "This is hard to say, but...", "alt": ["I hate to say this, but..."], "function": "standard", "note": "切り出しのクッション。" },
    { "id": "lv3-029", "jp": "そういうことか。", "en": "That makes sense now.", "alt": ["Oh, I see."], "function": "standard", "note": "腑に落ちた時。" },
    { "id": "lv3-030", "jp": "今のところ順調だよ。", "en": "So far, so good.", "alt": [], "function": "standard", "note": "決まり文句。" }
  ]
}
